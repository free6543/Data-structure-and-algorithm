class Solution {
public:
    int trap(vector<int>& height) {
        int water=0;
        stack<int>st;
        //保存柱子的位置i
        for(int i=0;i<height.size();i++)
        {
            while(!st.empty()&&height[st.top()]<height[i])
            {
                int low=st.top();
                st.pop();
                if(st.empty())
                {
                    break;
                }
                //计算出左右边界距离
                int d=i-st.top()-1;
                int h=min(height[st.top()],height[i]);
                water+=d*(h-height[low]);
            }
            st.push(i);
        }
         return water;
    }
};
